# This backend needs NO config by default — it calls a free, public BiRefNet
# Space (not-lain/background-removal) anonymously. Copy this file to server/.env
# only if you want to override something below.

# Point at your own Space (e.g. after duplicating one into your HF account):
# HF_SPACE=your-username/background-removal
# HF_ENDPOINT=/png

# Only needed for private or ZeroGPU-gated Spaces (free token, no card required):
# HF_TOKEN=hf_xxx

# PORT=8787
